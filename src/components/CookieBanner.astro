---
// Cookie consent banner — essential cookies only notice
---

<div
    id="cookie-banner"
    role="dialog"
    aria-label="Cookie notice"
    aria-live="polite"
    class="fixed bottom-6 left-4 right-4 sm:left-1/2 sm:-translate-x-1/2 sm:right-auto sm:w-full sm:max-w-2xl z-50 transform transition-all duration-500 ease-out"
    style="display: none;"
>
    <div class="bg-skill-wanderer-card-dark border border-white/10 rounded-2xl shadow-2xl px-5 py-5 sm:px-6">
        <div class="flex items-center gap-4 sm:gap-5">
            <!-- Shield icon -->
            <div class="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-skill-wanderer-primary-orange/15">
                <svg class="w-5 h-5 text-skill-wanderer-primary-orange" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-1.5 14.59l-3.59-3.59L8.32 10.59 10.5 12.77l5.18-5.18L17.09 9l-6.59 6.59z"/>
                </svg>
            </div>

            <!-- Text content -->
            <div class="flex-1 min-w-0">
                <h3 class="text-sm font-bold text-skill-wanderer-primary-orange uppercase tracking-wider mb-1">Essential Cookies Only</h3>
                <p class="text-sm text-skill-wanderer-text-dark-secondary leading-snug">
                    Only the minimum cookies required for this site to function. No tracking, no advertising, no profiling.
                    &nbsp;<a
                        href="https://skill-wanderer.com/cookie-policy"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-skill-wanderer-text-dark-secondary hover:text-skill-wanderer-primary-orange transition-colors duration-200 font-medium whitespace-nowrap"
                    >Cookie policy &rarr;</a>
                </p>
            </div>

            <!-- Got it button -->
            <button
                id="cookie-accept"
                type="button"
                class="flex-shrink-0 border border-skill-wanderer-text-dark-muted/40 hover:border-skill-wanderer-primary-orange text-skill-wanderer-text-dark-secondary hover:text-skill-wanderer-primary-orange text-sm font-semibold px-6 py-2.5 rounded-xl transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-skill-wanderer-primary-orange/50 focus:ring-offset-2 focus:ring-offset-skill-wanderer-card-dark"
            >
                Got it
            </button>
        </div>
    </div>
</div>

<script>
    const STORAGE_KEY = 'sw-cookie-notice-dismissed';
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('cookie-accept');

    function hideBanner() {
        if (banner) {
            banner.style.opacity = '0';
            banner.style.transform = 'translateY(1rem) scale(0.97)';
            setTimeout(() => { banner.style.display = 'none'; }, 500);
        }
    }

    if (banner && !localStorage.getItem(STORAGE_KEY)) {
        banner.style.display = 'block';
        banner.style.opacity = '0';
        banner.style.transform = 'translateY(1rem) scale(0.97)';
        // Small delay so the entrance animation is visible
        requestAnimationFrame(() => {
            requestAnimationFrame(() => {
                banner.style.opacity = '1';
                banner.style.transform = 'translateY(0) scale(1)';
            });
        });
    }

    acceptBtn?.addEventListener('click', () => {
        localStorage.setItem(STORAGE_KEY, '1');
        hideBanner();
    });
</script>
