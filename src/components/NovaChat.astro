---
// NovaChat.astro — Nova the Story Weaver chatbot
// Storyteller personality for wanderings.skill-wanderer.com
// src/components/NovaChat.astro
const apiUrl = import.meta.env.PUBLIC_PATHFINDER_API_URL || '';
---

<!-- Floating Action Button -->
<button id="nova-fab" class="nova-fab" aria-label="Open Nova chat">
  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5l6.74-6.76z"/>
    <line x1="16" y1="8" x2="2" y2="22"/>
    <line x1="17.5" y1="15" x2="9" y2="15"/>
  </svg>
  <span class="nova-fab-ring"></span>
</button>

<!-- Chat Panel -->
<div id="nova-panel" class="nova-panel" style="display:none" data-api-url={apiUrl}>
  <!-- Starfield -->
  <div id="nova-stars" class="nova-stars" aria-hidden="true"></div>

  <button class="nova-mobile-close" id="nova-mobile-close" type="button" title="Close chat" aria-label="Close chat">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
    <span>Close</span>
  </button>

  <!-- Header -->
  <div class="nova-header">
    <div class="nova-header-left">
      <svg class="nova-header-icon" width="22" height="22" viewBox="0 0 24 24" fill="#FF8C42" stroke="none">
        <path d="M12 2l2.09 6.26L20.18 9l-5 4.09L16.82 20 12 16.27 7.18 20l1.64-6.91L3.82 9l6.09-.74z"/>
      </svg>
      <div class="nova-header-info">
        <span class="nova-title-text">Nova</span>
        <span class="nova-subtitle">STORY WEAVER</span>
      </div>
    </div>
    <div class="nova-header-right">
      <button class="nova-header-btn nova-reset-btn" id="nova-reset" title="New chapter" aria-label="New chapter">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
          <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
        </svg>
      </button>
      <button class="nova-header-btn nova-close-btn" id="nova-close" title="Close" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Messages area -->
  <div id="nova-messages" class="nova-messages">
    <!-- Welcome screen (shown when empty) -->
    <div id="nova-welcome" class="nova-welcome">
      <img 
        src="/images/nova.webp" 
        alt="Nova" 
        class="nova-welcome-avatar"
      />
      <div class="nova-welcome-title">Welcome, Wanderer!</div>
      <div class="nova-welcome-desc">Every star has a story, and this one begins with your question. Ask me anything about the wanderings&hellip;</div>
      <div id="nova-suggestions" class="nova-suggestions">
        <button class="nova-suggestion" data-q="What stories live here?">What stories live here?</button>
        <button class="nova-suggestion" data-q="Tell me about Skill-Wanderer">Tell me about Skill-Wanderer</button>
        <button class="nova-suggestion" data-q="Recommend a read">Recommend a read</button>
      </div>
    </div>
  </div>

  <!-- Error bar -->
  <div id="nova-error" class="nova-error" style="display:none"></div>

  <!-- Privacy notice -->
  <div class="nova-privacy-notice">
    We may store and analyze anonymized conversations to improve the system. You can request deletion at any time. Please avoid sharing personal or sensitive information.
  </div>

  <!-- Input bar -->
  <form id="nova-input-form" class="nova-input-bar" autocomplete="off">
    <input id="nova-input" type="text" class="nova-input" placeholder="What story shall we explore…" maxlength="2000" />
    <button id="nova-send" type="submit" class="nova-send-btn" disabled aria-label="Send message">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4.5 16.5L3 22l5.5-1.5"/>
        <path d="M15 2l7 7-10.5 10.5L4 12z"/>
        <path d="M9.5 14.5l5-5"/>
      </svg>
    </button>
  </form>
</div>

<style is:global>
  /* ───── Nova Chat — Global Styles ───── */

  /* FAB */
  .nova-fab {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #FF8C42, #FF6B35 50%, #E85D25);
    border: 2px solid rgba(255, 217, 61, 0.3);
    box-shadow: 0 4px 24px rgba(255, 107, 53, 0.45);
    cursor: pointer;
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: nova-pulse 3s ease-in-out infinite;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .nova-fab:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 32px rgba(255, 107, 53, 0.6);
    animation: none;
  }
  .nova-fab-ring {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1.5px dashed rgba(255, 217, 61, 0.25);
    animation: nova-spin 12s linear infinite;
    pointer-events: none;
  }

  /* Panel */
  .nova-panel {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 390px;
    height: 540px;
    max-width: calc(100vw - 2rem);
    max-height: calc(100vh - 3rem);
    background: #0d1117;
    border: 1px solid rgba(255, 217, 61, 0.12);
    border-radius: 18px;
    box-shadow: 0 8px 48px rgba(0,0,0,0.6), 0 0 1px rgba(255,107,53,0.3), inset 0 1px 0 rgba(255,255,255,0.04);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    opacity: 0;
    transform: translateY(24px) scale(0.92);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .nova-panel.nova-panel-open {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* Starfield */
  .nova-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .nova-star {
    position: absolute;
    width: 2px;
    height: 2px;
    background: #fff;
    border-radius: 50%;
    animation: nova-twinkle 4s ease-in-out infinite;
  }
  .nova-star:nth-child(odd) { animation-duration: 3s; }
  .nova-star:nth-child(3n) { animation-duration: 5s; width: 1px; height: 1px; }
  .nova-star:nth-child(n+21) { display: none; }

  /* Header */
  .nova-header {
    padding: 0.75rem 1rem;
    background: linear-gradient(135deg, rgba(255,107,53,0.12) 0%, rgba(13,17,23,0.95) 100%);
    border-bottom: 1px solid rgba(255, 217, 61, 0.08);
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 1;
  }
  .nova-header-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .nova-header-icon {
    animation: nova-orbit-bob 6s ease-in-out infinite;
  }
  .nova-header-info {
    display: flex;
    flex-direction: column;
  }
  .nova-title-text {
    font-size: 0.875rem;
    font-weight: bold;
    background: linear-gradient(135deg, #FFD93D, #FF6B35);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.2;
  }
  .nova-subtitle {
    font-size: 10px;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.12em;
    line-height: 1.2;
  }
  .nova-header-right {
    display: flex;
    gap: 0.25rem;
  }
  .nova-header-btn {
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.45);
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease, background 0.2s ease;
  }
  .nova-header-btn:hover {
    color: #FFD93D;
    background: rgba(255,217,61,0.08);
  }
  .nova-mobile-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: none;
    align-items: center;
    gap: 0.35rem;
    min-height: 44px;
    padding: 0.625rem 0.875rem;
    border: 1px solid rgba(255, 217, 61, 0.18);
    border-radius: 999px;
    background: rgba(13, 17, 23, 0.88);
    color: #f6f6f6;
    cursor: pointer;
    z-index: 2;
    backdrop-filter: blur(10px);
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .nova-mobile-close:hover {
    background: rgba(255, 107, 53, 0.18);
    border-color: rgba(255, 217, 61, 0.32);
    color: #FFD93D;
  }
  .nova-mobile-close span {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  /* Messages area */
  .nova-messages {
    flex: 1;
    overflow-y: auto;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,107,53,0.2) transparent;
  }
  .nova-messages::-webkit-scrollbar { width: 4px; }
  .nova-messages::-webkit-scrollbar-track { background: transparent; }
  .nova-messages::-webkit-scrollbar-thumb { background: rgba(255,107,53,0.2); border-radius: 4px; }

  /* Welcome */
  .nova-welcome {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem 1rem 1rem;
    color: #b0b0b0;
    flex: 1;
  }
  .nova-welcome-icon {
    animation: nova-orbit-bob 5s ease-in-out infinite;
    margin-bottom: 0.75rem;
  }
  .nova-welcome-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #e0e0e0;
    margin-bottom: 0.25rem;
  }
  .nova-welcome-desc {
    font-size: 0.75rem;
    opacity: 0.6;
    line-height: 1.5;
    max-width: 280px;
    margin-bottom: 1rem;
  }
  .nova-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
  }
  .nova-suggestion {
    background: rgba(255,107,53,0.08);
    border: 1px solid rgba(255,107,53,0.2);
    color: #FF8C42;
    font-size: 0.6875rem;
    padding: 5px 10px;
    border-radius: 20px;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
    font-family: inherit;
  }
  .nova-suggestion:hover {
    background: rgba(255,107,53,0.18);
    border-color: rgba(255,107,53,0.4);
  }

  /* Message rows */
  .nova-msg {
    display: flex;
    gap: 6px;
    max-width: 100%;
  }
  .nova-msg-user {
    justify-content: flex-end;
  }
  .nova-msg-assistant {
    justify-content: flex-start;
  }

  /* Avatar */
  .nova-avatar {
    width: 24px;
    height: 24px;
    min-width: 24px;
    border-radius: 50%;
    background: rgba(255,107,53,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }

  /* Bubbles */
  .nova-bubble {
    max-width: 82%;
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    line-height: 1.55;
    word-break: break-word;
  }
  .nova-msg-user .nova-bubble {
    background: linear-gradient(135deg, #FF6B35, #E85D25);
    color: #fff;
    border-radius: 14px;
    border-bottom-right-radius: 4px;
    box-shadow: 0 2px 8px rgba(255,107,53,0.2);
  }
  .nova-msg-assistant .nova-bubble {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.06);
    color: #d0d0d0;
    border-radius: 14px;
    border-bottom-left-radius: 4px;
  }
  .nova-msg-assistant .nova-bubble a {
    color: #FFD93D;
    text-decoration: underline;
    text-decoration-color: rgba(255,217,61,0.3);
  }
  .nova-msg-assistant .nova-bubble a:hover {
    text-decoration-color: #FFD93D;
  }

  /* Typing indicator */
  .nova-typing {
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 0.6rem 0.75rem;
  }
  .nova-typing span {
    width: 6px;
    height: 6px;
    background: #FF8C42;
    border-radius: 50%;
    animation: nova-dot 1.4s infinite both;
  }
  .nova-typing span:nth-child(2) { animation-delay: 0.2s; }
  .nova-typing span:nth-child(3) { animation-delay: 0.4s; }

  /* Sources */
  .nova-sources {
    margin-left: 2rem;
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }
  .nova-sources-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.4;
    color: #e0e0e0;
    margin-bottom: 4px;
  }
  .nova-source-link {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.6875rem;
    color: #FFD93D;
    opacity: 0.7;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 280px;
    transition: opacity 0.15s ease;
  }
  .nova-source-link:hover {
    opacity: 1;
  }
  .nova-source-link svg {
    min-width: 10px;
    opacity: 0.6;
  }

  /* Clear chat */
  .nova-clear-chat {
    display: flex;
    justify-content: center;
    padding-top: 0.5rem;
  }
  .nova-clear-btn {
    background: rgba(255,107,53,0.08);
    border: 1px solid rgba(255,107,53,0.2);
    color: #FF8C42;
    font-size: 0.6875rem;
    padding: 5px 12px;
    border-radius: 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: inherit;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .nova-clear-btn:hover {
    background: rgba(255,107,53,0.18);
    border-color: rgba(255,107,53,0.4);
  }

  /* Error bar */
  .nova-error {
    background: rgba(255, 107, 107, 0.06);
    border-top: 1px solid rgba(255, 107, 107, 0.15);
    color: #ff6b6b;
    font-size: 0.75rem;
    padding: 0.5rem 1rem;
    position: relative;
    z-index: 1;
  }

  /* Privacy notice */
  .nova-privacy-notice {
    padding: 0.375rem 0.75rem;
    background: rgba(13, 17, 23, 0.95);
    border-top: 1px solid rgba(255, 217, 61, 0.08);
    font-size: 0.625rem;
    color: rgba(180, 180, 180, 0.7);
    text-align: center;
    line-height: 1.4;
    position: relative;
    z-index: 1;
  }

  /* Input bar */
  .nova-input-bar {
    padding: 0.625rem 0.75rem;
    background: rgba(13, 17, 23, 0.95);
    border-top: 1px solid rgba(255, 217, 61, 0.08);
    display: flex;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .nova-input {
    flex: 1;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    color: #e0e0e0;
    outline: none;
    font-family: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .nova-input::placeholder {
    color: #555;
    font-style: italic;
  }
  .nova-input:focus {
    border-color: rgba(255,107,53,0.4);
    box-shadow: 0 0 0 2px rgba(255,107,53,0.08);
  }
  .nova-send-btn {
    width: 38px;
    height: 38px;
    min-width: 38px;
    background: linear-gradient(135deg, #FF6B35, #E85D25);
    border: none;
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease;
  }
  .nova-send-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }
  .nova-send-btn:not(:disabled):hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(255,107,53,0.35);
  }

  /* ───── Animations ───── */
  @keyframes nova-pulse {
    0%, 100% { box-shadow: 0 4px 24px rgba(255,107,53,0.45); }
    50% { box-shadow: 0 4px 32px rgba(255,107,53,0.7), 0 0 48px rgba(255,107,53,0.15); }
  }
  @keyframes nova-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes nova-twinkle {
    0%, 100% { opacity: 0; }
    50% { opacity: 0.8; }
  }
  @keyframes nova-orbit-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
  }
  @keyframes nova-dot {
    0%, 80%, 100% { transform: scale(0.7); opacity: 0.2; }
    40% { transform: scale(1); opacity: 1; }
  }

  /* ───── Responsive / Mobile ───── */
  @media (max-width: 480px) {
    .nova-fab {
      bottom: 1rem;
      right: 1rem;
    }
    .nova-panel {
      width: 100vw;
      height: 100vh;
      max-width: 100vw;
      max-height: 100vh;
      bottom: 0;
      right: 0;
      border-radius: 0;
    }
    .nova-header {
      padding-top: calc(0.75rem + env(safe-area-inset-top, 0px));
      padding-right: 5.75rem;
    }
    .nova-input-bar {
      padding-bottom: calc(0.625rem + env(safe-area-inset-bottom, 0px));
    }
    .nova-close-btn {
      display: none;
    }
    .nova-mobile-close {
      top: calc(0.75rem + env(safe-area-inset-top, 0px));
      right: calc(0.75rem + env(safe-area-inset-right, 0px));
      display: inline-flex;
    }
  }
</style>

<script>
  const NOVA_AVATAR_HTML = `
    <img 
      src="/images/nova.webp" 
      alt="Nova AI" 
      class="nova-avatar-img"
      loading="lazy"
    />
  `;
  document.addEventListener('astro:page-load', initNova);
  document.addEventListener('DOMContentLoaded', initNova);

  let novaInitialized = false;

  function initNova() {
    if (novaInitialized) return;
    novaInitialized = true;

    // ─── Elements ───
    const fab = document.getElementById('nova-fab');
    const panel = document.getElementById('nova-panel');
    const closeBtn = document.getElementById('nova-close');
    const mobileCloseBtn = document.getElementById('nova-mobile-close');
    const resetBtn = document.getElementById('nova-reset');
    const messagesEl = document.getElementById('nova-messages');
    const welcomeEl = document.getElementById('nova-welcome');
    const errorEl = document.getElementById('nova-error');
    const form = document.getElementById('nova-input-form') as HTMLFormElement;
    const input = document.getElementById('nova-input') as HTMLInputElement;
    const sendBtn = document.getElementById('nova-send') as HTMLButtonElement;
    const starsEl = document.getElementById('nova-stars');

    if (!fab || !panel || !messagesEl || !form || !input || !sendBtn) return;

    const apiUrl = panel.dataset.apiUrl || '';
    const DOMAIN = 'wanderings.skill-wanderer.com';
    const PERSONALITY = 'storyteller';
    const SESSION_KEY = 'nova_chat_session';
    const SESSION_EXPIRY_MIN = 30;

    // ─── State ───
    interface ChatMessage { role: 'user' | 'assistant'; content: string; }
    interface Source { title: string; url: string; chunk_index: number; total_chunks: number; score: number; }
    let history: ChatMessage[] = [];
    let loading = false;

    // ─── Starfield ───
    if (starsEl) {
      for (let i = 0; i < 25; i++) {
        const star = document.createElement('span');
        star.className = 'nova-star';
        star.style.left = Math.random() * 100 + '%';
        star.style.top = Math.random() * 100 + '%';
        star.style.animationDelay = (Math.random() * 5) + 's';
        starsEl.appendChild(star);
      }
    }

    // ─── Session persistence ───
    function saveSession() {
      try {
        const data = {
          history,
          personality: PERSONALITY,
          expiresAt: Date.now() + SESSION_EXPIRY_MIN * 60 * 1000,
        };
        localStorage.setItem(SESSION_KEY, JSON.stringify(data));
      } catch { /* storage full or unavailable */ }
    }

    function loadSession() {
      try {
        const raw = localStorage.getItem(SESSION_KEY);
        if (!raw) return;
        const data = JSON.parse(raw);
        if (data.expiresAt && Date.now() > data.expiresAt) {
          localStorage.removeItem(SESSION_KEY);
          return;
        }
        if (Array.isArray(data.history) && data.history.length > 0) {
          history = data.history;
        }
      } catch {
        localStorage.removeItem(SESSION_KEY);
      }
    }

    function clearSession() {
      history = [];
      localStorage.removeItem(SESSION_KEY);
    }

    // ─── Rendering ───
    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function renderMarkdown(text: string): string {
      let html = escapeHtml(text);
      // Bold
      html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      // Italic
      html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
      // Inline code
      html = html.replace(/`([^`]+)`/g, '<code style="background:rgba(255,255,255,0.08);padding:1px 4px;border-radius:3px;font-size:0.8em;">$1</code>');
      // Links [text](url) — only allow http/https
      html = html.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
      // Unordered lists
      html = html.replace(/^[-•] (.+)$/gm, '<li style="margin-left:1rem;list-style:disc inside;">$1</li>');
      // Numbered lists
      html = html.replace(/^\d+\. (.+)$/gm, '<li style="margin-left:1rem;list-style:decimal inside;">$1</li>');
      // Paragraphs (double newline)
      html = html.replace(/\n\n/g, '<br><br>');
      // Single newlines
      html = html.replace(/\n/g, '<br>');
      return html;
    }

    function renderMessages(opts?: { skipLast?: boolean }) {
      if (!messagesEl || !welcomeEl) return;

      // Clear everything except welcome
      const existingMsgs = messagesEl.querySelectorAll('.nova-msg, .nova-sources, .nova-clear-chat, .nova-typing-row');
      existingMsgs.forEach(el => el.remove());

      if (history.length === 0) {
        welcomeEl.style.display = 'flex';
        return;
      }

      welcomeEl.style.display = 'none';

      const msgs = opts?.skipLast ? history.slice(0, -1) : history;

      msgs.forEach(msg => {
        const row = document.createElement('div');
        row.className = `nova-msg nova-msg-${msg.role}`;

        if (msg.role === 'assistant') {
          // Avatar
          const avatar = document.createElement('div');
          avatar.className = 'nova-avatar';
          avatar.innerHTML = NOVA_AVATAR_HTML;
          row.appendChild(avatar);
        }

        const bubble = document.createElement('div');
        bubble.className = 'nova-bubble';
        bubble.innerHTML = renderMarkdown(msg.content);
        row.appendChild(bubble);

        messagesEl.appendChild(row);
      });

      // Clear chat button
      if (!loading) {
        const clearRow = document.createElement('div');
        clearRow.className = 'nova-clear-chat';
        clearRow.innerHTML = `<button class="nova-clear-btn">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
          </svg>
          Start a new chapter
        </button>`;
        clearRow.querySelector('.nova-clear-btn')?.addEventListener('click', resetChat);
        messagesEl.appendChild(clearRow);
      }

      scrollToBottom();
    }

    function showTyping() {
      if (!messagesEl) return;
      const row = document.createElement('div');
      row.className = 'nova-msg nova-msg-assistant nova-typing-row';
      const avatar = document.createElement('div');
      avatar.className = 'nova-avatar';
      avatar.innerHTML = NOVA_AVATAR_HTML;
      row.appendChild(avatar);
      const bubble = document.createElement('div');
      bubble.className = 'nova-bubble';
      bubble.innerHTML = '<div class="nova-typing"><span></span><span></span><span></span></div>';
      row.appendChild(bubble);
      messagesEl.appendChild(row);
      scrollToBottom();
    }

    function hideTyping() {
      messagesEl?.querySelectorAll('.nova-typing-row').forEach(el => el.remove());
    }

    // ─── Typewriter effect ───
    function typewriteAssistant(text: string): Promise<void> {
      return new Promise(resolve => {
        if (!messagesEl) { resolve(); return; }

        const row = document.createElement('div');
        row.className = 'nova-msg nova-msg-assistant';

        const avatar = document.createElement('div');
        avatar.className = 'nova-avatar';
        avatar.innerHTML = NOVA_AVATAR_HTML;
        row.appendChild(avatar);

        const bubble = document.createElement('div');
        bubble.className = 'nova-bubble';
        row.appendChild(bubble);
        messagesEl.appendChild(row);

        // Split into words, reveal in fast batches
        const words = text.split(/(\s+)/);  // keep whitespace tokens
        let wordIndex = 0;
        let accumulated = '';
        const WORDS_PER_TICK = 3;
        const TICK_MS = 30;

        function tick() {
          const end = Math.min(wordIndex + WORDS_PER_TICK, words.length);
          for (let i = wordIndex; i < end; i++) {
            accumulated += words[i];
          }
          wordIndex = end;
          bubble.innerHTML = renderMarkdown(accumulated);
          scrollToBottom();

          if (wordIndex < words.length) {
            requestAnimationFrame(() => setTimeout(tick, TICK_MS));
          } else {
            resolve();
          }
        }
        tick();
      });
    }

    function renderSources(sources: Source[]) {
      if (!messagesEl || sources.length === 0) return;
      const container = document.createElement('div');
      container.className = 'nova-sources';
      container.innerHTML = '<div class="nova-sources-label">Discovered Tales</div>';
      sources.forEach(s => {
        const a = document.createElement('a');
        a.className = 'nova-source-link';
        a.href = s.url;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.innerHTML = `<svg width="10" height="10" viewBox="0 0 24 24" fill="#FFD93D" stroke="none"><path d="M12 2l2.09 6.26L20.18 9l-5 4.09L16.82 20 12 16.27 7.18 20l1.64-6.91L3.82 9l6.09-.74z"/></svg>`;
        const span = document.createElement('span');
        span.textContent = s.title || s.url;
        a.appendChild(span);
        container.appendChild(a);
      });
      messagesEl.appendChild(container);
      scrollToBottom();
    }

    function showError(msg: string) {
      if (!errorEl) return;
      errorEl.textContent = msg;
      errorEl.style.display = 'block';
    }

    function hideError() {
      if (!errorEl) return;
      errorEl.style.display = 'none';
    }

    function scrollToBottom() {
      if (!messagesEl) return;
      requestAnimationFrame(() => {
        messagesEl.scrollTop = messagesEl.scrollHeight;
      });
    }

    // ─── API ───
    async function sendMessage(question: string) {
      if (loading || !question.trim()) return;

      hideError();
      loading = true;
      sendBtn.disabled = true;

      // Add user message
      history.push({ role: 'user', content: question.trim() });
      renderMessages();
      showTyping();

      try {
        if (!apiUrl) throw new Error('Chat API is not configured.');

        const res = await fetch(`${apiUrl}/api/chat`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            question: question.trim(),
            domains: [DOMAIN],
            personality: PERSONALITY,
            history: history.slice(0, -1).slice(-50),
          }),
        });

        if (!res.ok) {
          throw new Error(res.status === 422 ? 'Invalid request. Please try rephrasing.' : `Something went wrong (${res.status}).`);
        }

        const data = await res.json();
        history.push({ role: 'assistant', content: data.answer });
        saveSession();

        hideTyping();
        // Render all prior messages instantly, then typewrite the latest one
        renderMessages({ skipLast: true });
        await typewriteAssistant(data.answer);
        // Re-render fully so clear-chat button appears
        renderMessages();

        if (data.sources && data.sources.length > 0) {
          renderSources(data.sources);
        }
      } catch (err: any) {
        hideTyping();
        history.pop(); // remove user message on failure
        renderMessages();
        showError(err.message || 'Failed to send message.');
      } finally {
        loading = false;
        updateSendState();
      }
    }

    function resetChat() {
      clearSession();
      hideError();
      renderMessages();
    }

    function updateSendState() {
      sendBtn.disabled = loading || !input.value.trim();
    }

    // ─── Panel toggle ───
    function openPanel() {
      fab!.style.display = 'none';
      panel!.style.display = 'flex';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          panel!.classList.add('nova-panel-open');
        });
      });
      input.focus();
    }

    function closePanel() {
      panel!.classList.remove('nova-panel-open');
      panel!.addEventListener('transitionend', function handler() {
        panel!.removeEventListener('transitionend', handler);
        panel!.style.display = 'none';
        fab!.style.display = 'flex';
      });
    }

    // ─── Event listeners ───
    fab.addEventListener('click', openPanel);
    closeBtn?.addEventListener('click', closePanel);
    mobileCloseBtn?.addEventListener('click', closePanel);
    resetBtn?.addEventListener('click', resetChat);

    form.addEventListener('submit', (e: Event) => {
      e.preventDefault();
      const question = input.value;
      input.value = '';
      updateSendState();
      sendMessage(question);
    });

    input.addEventListener('input', updateSendState);

    // Suggestion pills
    document.querySelectorAll('.nova-suggestion').forEach(btn => {
      btn.addEventListener('click', () => {
        const q = (btn as HTMLElement).dataset.q;
        if (q) sendMessage(q);
      });
    });

    // Keyboard: Escape to close
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && panel!.style.display !== 'none') {
        closePanel();
      }
    });

    // ─── Init ───
    loadSession();
    renderMessages();
  }
</script>
